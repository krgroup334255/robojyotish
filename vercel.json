{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/process/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/admin/release/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/admin/regenerate/route.ts": {
      "maxDuration": 300
    }
  },
  "regions": ["sin1"]
}
